# ──────────────────────────────────────────────────
# Azure AI Foundry (required)
# ──────────────────────────────────────────────────
AZURE_AI_PROJECT_CONNECTION_STRING=your-project-connection-string-here
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# ──────────────────────────────────────────────────
# Azure OpenAI (required if not using project connection string)
# ──────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-11-20

# ──────────────────────────────────────────────────
# Azure AI Search — Foundry IQ knowledge base (required)
# ──────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-search-resource.search.windows.net
AZURE_SEARCH_API_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_NAME=fractured-orbit-lore

# ──────────────────────────────────────────────────
# Azure Cosmos DB — game state persistence (required)
# ──────────────────────────────────────────────────
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=fractured_orbit
COSMOS_CONTAINER=game_sessions

# ──────────────────────────────────────────────────
# Azure Blob Storage — world data upload (required for setup)
# ──────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=world-data

# ──────────────────────────────────────────────────
# Application Insights — telemetry (required)
# ──────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;...
